# Frontend environment variables
# Copy this file to frontend/.env and replace the sample values.

# Port used by the frontend app
PORT=3000

# Separate Next.js build output for the frontend process.
NEXT_DIST_DIR=.next-frontend

# Internal API base URL used by server-rendered frontend routes.
API_BASE_URL=http://127.0.0.1:4000

# Public API base URL used by browser fetch calls.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Public socket server URL used by the live match screen.
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

# Must match the backend secret because shared server-side code verifies cookies.
JWT_SECRET=replace-with-the-same-secret-used-in-backend

# Public Cloudinary cloud name for building image URLs on the client if needed.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
