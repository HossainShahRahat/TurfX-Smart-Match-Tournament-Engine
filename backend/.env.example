# Backend environment variables
# Copy this file to backend/.env and replace the sample values.

NODE_ENV=development
BACKEND_PORT=4000
FRONTEND_ORIGIN=http://localhost:3000

# MongoDB connection string for local development.
MONGODB_URI=mongodb://127.0.0.1:27017/turfx

# Secret used to sign and verify auth tokens.
JWT_SECRET=replace-with-a-long-random-secret

# Cloudinary credentials for image upload and delivery.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
